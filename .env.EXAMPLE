# hermes-research-agent — required environment variables
# Copy this file to .env and fill in your own values.
# Never commit .env to git — it contains your private keys.

# ── Model access ──────────────────────────────────────────────────────────────
# Option 1 — Nous Portal (recommended): no API key needed here.
#   Run: hermes setup --portal
#   OAuth token is shared across all profiles automatically.
#   See README for full setup instructions.
#
# Option 2 — OpenRouter: paste your key below.
#   Account free at openrouter.ai, but needs ~$5 in credits loaded.
#   Do NOT use free-tier models — rate limits and latency break cron jobs.
#   Recommended: deepseek/deepseek-v4-flash (~$0.10/day, ~$3/month for all 3 jobs)
OPENROUTER_API_KEY=

# ── Telegram delivery ─────────────────────────────────────────────────────────
# Create a bot via @BotFather → /newbot → copy the token here
TELEGRAM_BOT_TOKEN=

# Your Telegram user ID (numbers only). Get it from @userinfobot
TELEGRAM_ALLOWED_USERS=

# ── Obsidian vault ────────────────────────────────────────────────────────────
# Absolute path to your local Obsidian vault folder
# Windows example: C:/Users/YourName/Documents/obsidian-vault
# macOS/Linux example: /home/yourname/obsidian-vault
OBSIDIAN_VAULT_PATH=

# ── Finnhub (optional — needed for market-scan) ───────────────────────────────
# Free API key at finnhub.io → covers stocks, ETFs, crypto, gold/silver
# Leave blank to skip market-scan real-time prices (will fall back to web search)
FINNHUB_API_KEY=
